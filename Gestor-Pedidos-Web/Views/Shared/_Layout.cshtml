<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title Aplicacion de Gestion de Pedidos</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-md navbar-dark bg-dark fixed-top">
        <div class="container">
            <a href="@Url.Action("Index", "Pedidos")" class="navbar-brand"><i class="bi bi-boxes"></i> Gestion de Pedidos</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse"
                    aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Pedidos")" class="nav-link"><i class="bi bi-box-seam"></i> Pedidos</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Index", "Clientes")" class="nav-link"><i class="bi bi-person"></i> Clientes</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <main class="container body-content flex-grow-1" style="margin-top: 70px;">
        @RenderBody()
    </main>
    <hr />
    <footer class="container">
        <p>&copy; @DateTime.Now.Year - Aplicacion para Gestion de Pedidos</p>
    </footer>

    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>