@model IEnumerable<Shared.DTOs.ClientesDTO>

@{
    ViewBag.Title = "Clientes";
}

<div class="container">
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-6">
            <h2>
                Clientes
                <a href="@Url.Action("Create", "Clientes")" class="text-success"><i class="bi bi-plus-square"></i></a>
            </h2>
        </div>
        <div class="col-6 text-end">
            <span>Hay @Model.Count() clientes.</span>
        </div>
        <div class="text-end">
            @using (Html.BeginForm("Buscar", "Clientes", FormMethod.Get))
            {
                <div class="d-flex gap-1 justify-content-sm-end">
                    @Html.TextBox("busqueda", null, new { @class = "form-control form-control-sm", placeholder = "Nombre o ciudad..." })
                    <button type="submit" class="btn btn-sm btn-secondary"><i class="bi bi-search"></i></button>
                </div>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-3">
            <i class="bi bi-info-circle"></i> No hay clientes.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table text-center table-striped table-hover table-bordered mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>
                            Nombre
                        </th>
                        <th>
                            Ciudad
                        </th>
                        <th>
                            Estatus
                        </th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @(item.Nombre?.ToString() ?? "Sin nombre")
                            </td>
                            <td>
                                @(item.Ciudad?.ToString() ?? "Sin ciudad")
                            </td>
                            <td>
                                @((item.Estatus ?? false) ? "Activo" : "Inactivo")
                            </td>
                            <td class="d-flex gap-2 justify-content-sm-center">
                                <a href="@Url.Action("Edit", "Clientes", new {id = item.ClientesId})" class="btn btn-sm btn-success" title="Editar cliente"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>